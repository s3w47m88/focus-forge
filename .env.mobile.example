# Mobile build/runtime defaults
USE_SUPABASE=true
REQUIRE_AUTH=true
IS_MOBILE=true
DATABASE_TYPE=supabase

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Capacitor server target control
CAPACITOR_SERVER=production
CAPACITOR_LOCAL_URL=http://localhost:3244
CAPACITOR_STAGING_URL=https://focusforge.theportlandcompany.com
CAPACITOR_PRODUCTION_URL=https://focusforge.theportlandcompany.com
# Optional hard override for all targets
# CAPACITOR_SERVER_URL=
